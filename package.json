{
  "name": "page-snap",
  "version": "1.2.0",
  "private": true,
  "description": "Chrome extension (MV3) for full-page, viewport, element, and multi-device screenshots",
  "type": "module",
  "scripts": {
    "build": "node build.mjs",
    "dev": "node build.mjs --watch",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "lint": "eslint src tests e2e && tsc --noEmit"
  },
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.7.0",
    "@playwright/test": "^1.45.0",
    "@types/chrome": "^0.0.268",
    "@types/node": "^26.1.1",
    "esbuild": "^0.23.0",
    "eslint": "^9.7.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.0.0"
  },
  "allowScripts": {
    "esbuild@0.23.1": true,
    "esbuild@0.21.5": true
  }
}
